# Índice local de CodeGraph (regenerable; no versionar)
.codegraph/

# Dependencias y artefactos de build (los crea /speckit-implement)
node_modules/
dist/

# Entornos virtuales de Python (p. ej. rembg para preparar art/iconos)
.venv/
.venv-*/

# Variables de entorno / secretos (nunca versionar)
.env
.env.*

# Logs y temporales
*.log

# Prompts de trabajo de Spec Kit (borradores, no versionar)
*.prompt

# Vídeos renderizados de los anuncios (regenerables con marketing/animations/render-videos.mjs)
marketing/animations/renders/

# Zips de assets para subir a claude.ai/design (redundantes: los PNG ya están versionados)
marketing/*.zip
