{
  "name": "topadero",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Prototipo de juego de plataformas de obstáculos en navegador (un jugador, local)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/check-asset-budgets.mjs",
    "assets:optimize": "node scripts/optimize-assets.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.4.0",
    "@gltf-transform/extensions": "^4.4.0",
    "@gltf-transform/functions": "^4.4.0",
    "@types/three": "^0.184.1",
    "meshoptimizer": "^1.1.1",
    "sharp": "^0.35.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
